rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "learninghubbd2126509574@gmail.com" &&
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    // Meetings Collection Rules
    match /meetings/{meetingId} {
      allow get, list, create, update, delete: if true;
    }

    // Participants Collection Rules
    match /participants/{participantId} {
      allow create, get, list, update, delete: if true;
    }

    // Blocked IPs Collection Rules
    match /blockedIPs/{ip} {
      allow get, list, create, update, delete: if true;
    }

    // Blocked Devices Collection Rules
    match /blockedDevices/{deviceId} {
      allow get, list, create, update, delete: if true;
    }

    // Admin Settings Rules
    match /adminSettings/{docId} {
      allow get, list, create, update, delete: if true;
    }
  }
}
